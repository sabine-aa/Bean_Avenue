// Bean Avenue database schema.
//
// Local development uses SQLite. To move to a hosted PostgreSQL later:
//   1. change `provider = "sqlite"` below to `provider = "postgresql"`
//   2. set DATABASE_URL in .env to your Postgres connection string
//   3. run `npm run db:push` (or `prisma migrate`) again.
// Nothing else in the app needs to change.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Menu categories with a manager-controlled display order.
model Category {
  id        Int    @id @default(autoincrement())
  name      String @unique
  sortOrder Int    @default(0)
}

model MenuItem {
  id          Int              @id @default(autoincrement())
  name        String
  category    String
  description String           @default("")
  price       Float            @default(0)
  options     String           @default("[]") // JSON-encoded OptionGroup[]
  tags        String           @default("[]") // JSON-encoded string[]
  photo         String?
  ingredients   String? // ingredients / allergen info (mainly for doughnuts)
  inStock       Boolean          @default(true) // false = sold out
  isHidden      Boolean          @default(false)
  availableToday Boolean         @default(true) // doughnuts: only show on the daily page when true
  sortOrder     Int              @default(0)
  featured      FeaturedProduct?
}

// Manager-curated homepage products ("The usual suspects"). References menu
// items live, so any Menu Manager edit shows up automatically — no copies.
model FeaturedProduct {
  id         Int      @id @default(autoincrement())
  menuItemId Int      @unique
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  sortOrder  Int      @default(0)
}

// Simple key/value store for site settings (e.g. homepage section title/visibility).
model Setting {
  key   String @id
  value String
}

model Room {
  id            Int       @id @default(autoincrement())
  name          String
  type          String // "STUDY" | "CONFERENCE"
  description   String    @default("")
  pricePerHour  Float
  capacityMin   Int
  capacityMax   Int
  openHour      Int
  closeHour     Int
  amenities     String    @default("[]") // JSON-encoded string[]
  rules         String    @default("[]") // JSON-encoded string[]
  images        String    @default("[]") // JSON-encoded string[]
  isAvailable   Boolean   @default(true)
  bufferMinutes Int       @default(0)
  bookings      Booking[]
}

model Customer {
  id            Int                  @id @default(autoincrement())
  name          String
  phone         String               @unique
  email         String?
  passwordHash  String? // null = phone-only "shell" account (e.g. created by a guest order)
  beanBalance   Int                  @default(0)
  lifetimeBeans Int                  @default(0)
  tier          String               @default("Bronze")
  isVip         Boolean              @default(false)
  noShowCount   Int                  @default(0)
  createdAt     DateTime             @default(now())
  orders        Order[]
  bookings      Booking[]
  transactions  LoyaltyTransaction[]
  redemptions   Redemption[]
  suggestions   Suggestion[]
  notifications Notification[]
}

// In-website notifications for a logged-in customer.
model Notification {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       String // "ORDER" | "BOOKING" | "REWARD" | "VOUCHER" | "POINTS"
  title      String
  message    String
  link       String? // in-app path to the related order/booking/reward
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// Customer feedback, ideas, or complaints. May be anonymous or tied to an account.
model Suggestion {
  id         Int       @id @default(autoincrement())
  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  name       String? // optional — may be left blank or pulled from the account
  phone      String? // optional — for contacting back
  message    String
  status     String    @default("NEW") // NEW | REVIEWED | RESOLVED
  adminNote  String?
  createdAt  DateTime  @default(now())
}

model LoyaltyTransaction {
  id           Int      @id @default(autoincrement())
  customerId   Int
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type         String // "EARN" | "REDEEM" | "ADJUST"
  amount       Int // positive = earned/added, negative = redeemed/removed
  balanceAfter Int      @default(0) // bean balance immediately after this transaction
  source       String
  refId        String? // order number, booking number, or redemption code
  note         String?
  createdAt    DateTime @default(now())
}

// A reward customers can spend beans on. Managed from the admin dashboard.
// Rewards are organised by menu category, with one or more per category.
model Reward {
  id           Int          @id @default(autoincrement())
  name         String
  description  String       @default("")
  category     String? // matches a menu category, e.g. "Espresso Based"
  cost         Int // beans required to redeem
  type         String       @default("FREE_ITEM") // "FREE_ITEM" | "DISCOUNT"
  icon         String       @default("🎁")
  image        String? // product image URL/path; falls back to icon when empty
  redeemMethod String       @default("Show voucher at counter")
  isActive     Boolean      @default(true) // show/hide on the customer page
  isAvailable  Boolean      @default(true) // can be redeemed right now
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())
  redemptions  Redemption[]
}

// A voucher created when a customer redeems a reward. Shown at the counter to claim.
model Redemption {
  id         Int       @id @default(autoincrement())
  code       String    @unique
  customerId Int
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rewardId   Int?
  reward     Reward?   @relation(fields: [rewardId], references: [id])
  rewardName String // snapshot, so it survives the reward being edited/deleted
  cost       Int // beans spent (snapshot)
  status     String    @default("ACTIVE") // "ACTIVE" | "CLAIMED" | "EXPIRED"
  createdAt  DateTime  @default(now())
  claimedAt  DateTime?
}

model Order {
  id           Int         @id @default(autoincrement())
  number       String      @unique
  customerId   Int?
  customer     Customer?   @relation(fields: [customerId], references: [id])
  customerName String
  phone        String
  email        String?
  subtotal     Float
  discount     Float       @default(0)
  total        Float
  promoCode    String?
  pickupTime   String?
  status       String      @default("NEW") // NEW | PREPARING | READY | PICKED_UP | CANCELLED
  cancelReason String?
  beansEarned  Int         @default(0)
  createdAt    DateTime    @default(now())
  items        OrderItem[]
}

model OrderItem {
  id                  Int     @id @default(autoincrement())
  orderId             Int
  order               Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId          Int? // kept so customers can re-order the same item later
  name                String
  unitPrice           Float
  quantity            Int
  selectedOptions     String  @default("[]") // JSON-encoded SelectedOption[]
  addons              String  @default("[]") // JSON-encoded { name, price, quantity }[]
  specialInstructions String?
  lineTotal           Float
}

// A group of add-ons (e.g. "Milk", "Syrup", "Extra shots"). Managed by the admin.
model AddonGroup {
  id          Int               @id @default(autoincrement())
  name        String
  selection   String            @default("MULTIPLE") // "SINGLE" | "MULTIPLE"
  minSelect   Int               @default(0) // minimum options a customer must pick (0 = optional)
  maxSelect   Int               @default(0) // maximum options a customer may pick (0 = no limit)
  isAvailable Boolean           @default(true)
  sortOrder   Int               @default(0)
  addons      Addon[]
  assignments AddonAssignment[]
}

// A single add-on within a group, with its own price and optional max quantity.
model Addon {
  id          Int        @id @default(autoincrement())
  groupId     Int
  group       AddonGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name        String
  price       Float      @default(0)
  maxQuantity Int        @default(1) // e.g. 3 for "up to 3 extra shots"
  isAvailable Boolean    @default(true)
  sortOrder   Int        @default(0)
}

// Links an add-on group to a specific drink OR to an entire menu category.
model AddonAssignment {
  id         Int        @id @default(autoincrement())
  groupId    Int
  group      AddonGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  menuItemId Int? // assign to one drink
  category   String? // assign to a whole category
}

// Events / workshops shown on the public Events page, managed from the admin.
model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @default("")
  startTime   DateTime
  price       Float    @default(0) // 0 = free
  spots       Int? // available spots, null = not tracked
  image       String?
  isHidden    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

// Customers who opted in to WhatsApp offers & updates.
model Subscriber {
  id        Int      @id @default(autoincrement())
  name      String?
  phone     String   @unique
  createdAt DateTime @default(now())
}

// Admin-controlled homepage announcement banner.
model Banner {
  id         Int       @id @default(autoincrement())
  title      String
  text       String    @default("")
  image      String?
  buttonText String?
  buttonLink String?
  startDate  DateTime?
  endDate    DateTime?
  isVisible  Boolean   @default(true)
  createdAt  DateTime  @default(now())
}

model Booking {
  id            Int       @id @default(autoincrement())
  number        String    @unique
  roomId        Int
  room          Room      @relation(fields: [roomId], references: [id])
  customerId    Int?
  customer      Customer? @relation(fields: [customerId], references: [id])
  customerName  String
  phone         String
  startTime     DateTime
  endTime       DateTime
  durationHours Int
  peopleCount   Int
  notes         String?
  total         Float
  status        String    @default("CONFIRMED") // PENDING | CONFIRMED | IN_USE | COMPLETED | CANCELLED | NO_SHOW
  beansEarned   Int       @default(0)
  createdAt     DateTime  @default(now())
}
