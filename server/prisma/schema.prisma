// Bean Avenue database schema.
//
// Local development uses SQLite. To move to a hosted PostgreSQL later:
//   1. change `provider = "sqlite"` below to `provider = "postgresql"`
//   2. set DATABASE_URL in .env to your Postgres connection string
//   3. run `npm run db:push` (or `prisma migrate`) again.
// Nothing else in the app needs to change.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Menu categories with a manager-controlled display order.
model Category {
  id        Int    @id @default(autoincrement())
  name      String @unique
  sortOrder Int    @default(0)
}

model MenuItem {
  id          Int              @id @default(autoincrement())
  name        String
  category    String
  subcategory String           @default("") // e.g. Hanson: Regular | Advanced | Special | Creation
  description String           @default("")
  price       Float            @default(0)
  costPrice   Float            @default(0) // cost to make (mainly Hanson doughnuts) — for profit reports
  options     String           @default("[]") // JSON-encoded OptionGroup[]
  tags        String           @default("[]") // JSON-encoded string[]
  photo         String?
  imageFit      String           @default("cover") // how the photo fills the card: "cover" | "contain"
  focalX        Int              @default(50) // focal point X % (0-100) — which part stays visible when cropped
  focalY        Int              @default(50) // focal point Y % (0-100)
  ingredients   String? // ingredients / allergen info (mainly for doughnuts)
  nutrition     String           @default("") // JSON {kcal,protein,carbs,fat,fibers} — mainly for Protein Drinks
  inStock       Boolean          @default(true) // false = sold out (manual override)
  isHidden      Boolean          @default(false)
  isBestSeller  Boolean          @default(false) // manager-flagged best seller (badge on the card)
  availableToday Boolean         @default(true) // doughnuts: only show on the daily page when true
  trackStock    Boolean          @default(false) // count finished-goods stock and auto-deduct on each sale
  stockQty      Int              @default(0) // units on hand (only meaningful when trackStock)
  lowStockAt    Int              @default(0) // alert threshold; stockQty <= this (and > 0) = low
  sortOrder     Int              @default(0)
  featured      FeaturedProduct?
  stockMoves    StockMovement[]
}

// An audit-logged change to a menu item's stock — every sale, restock, wastage
// or manual recount. The running stockQty is the sum of these deltas.
model StockMovement {
  id         Int      @id @default(autoincrement())
  menuItemId Int
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  delta      Int // signed: +restock/+recount-up, −sale/−waste
  balance    Int // stockQty after applying this delta
  type       String // SALE | RECEIVE | WASTE | ADJUST | COUNT
  reason     String?
  staffName  String?
  orderId    Int? // set when the movement came from a sale
  createdAt  DateTime @default(now())

  @@index([menuItemId, createdAt])
}

// Manager-curated homepage products ("The usual suspects"). References menu
// items live, so any Menu Manager edit shows up automatically — no copies.
// One homepage-featured menu item PER category (category-locked picker), so the
// carousel always shows variety. Admin picks one product per category, reorders,
// and can hide a category from the homepage.
model FeaturedProduct {
  id         Int      @id @default(autoincrement())
  category   String   @unique
  menuItemId Int      @unique
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  sortOrder  Int      @default(0)
  isHidden   Boolean  @default(false)
}

// Hanson Donuts daily production — its own inventory, SEPARATE from the café/shop
// stock. One row per doughnut per day: how many were made, how many sold, and
// end-of-day leftover handling. Remaining = made - sold. Sold-out when <= 0.
model HansonProduction {
  id            Int      @id @default(autoincrement())
  menuItemId    Int
  date          String // local day "YYYY-MM-DD"
  made          Int      @default(0)
  sold          Int      @default(0)
  wasted        Int      @default(0) // end-of-day leftover marked wasted
  leftoverAction String? // WASTED | STAFF | DISCOUNTED | CARRIED
  closed        Boolean  @default(false) // end-of-day closed
  notes         String?
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([menuItemId, date])
  @@index([date])
}

// Simple key/value store for site settings (e.g. homepage section title/visibility).
model Setting {
  key   String @id
  value String
}

model Room {
  id            Int       @id @default(autoincrement())
  name          String
  type          String // "STUDY" | "CONFERENCE"
  description   String    @default("")
  pricePerHour  Float
  capacityMin   Int
  capacityMax   Int
  openHour      Int
  closeHour     Int
  amenities     String    @default("[]") // JSON-encoded string[]
  rules         String    @default("[]") // JSON-encoded string[]
  images        String    @default("[]") // JSON-encoded string[]
  isAvailable   Boolean   @default(true)
  bufferMinutes Int       @default(0)
  bookings      Booking[]
}

model Customer {
  id            Int                  @id @default(autoincrement())
  name          String
  phone         String?              @unique // verified phone (E.164), nullable for email-only accounts
  phoneVerified Boolean              @default(false)
  email         String?              @unique
  emailVerified Boolean              @default(false)
  birthday      DateTime?
  birthdaySetAt DateTime? // when the birthday was first saved (locks it; gates the reward)
  birthdayNotifiedYear Int? // last birthday-window year we sent the "happy birthday" notification for
  googleId      String?              @unique // reserved for Google sign-in
  appleId       String?              @unique // reserved for Apple sign-in
  passwordHash  String? // legacy; no longer used (auth is OTP-based)
  beanBalance   Int                  @default(0)
  lifetimeBeans Int                  @default(0)
  tier          String               @default("Bronze")
  isVip         Boolean              @default(false)
  noShowCount   Int                  @default(0)
  createdAt     DateTime             @default(now())
  orders        Order[]
  bookings      Booking[]
  transactions  LoyaltyTransaction[]
  redemptions   Redemption[]
  suggestions   Suggestion[]
  notifications Notification[]
  birthdayVouchers BirthdayVoucher[]
  addresses     Address[]
}

// A complimentary birthday reward voucher (one free cupcake). Separate from the
// bean-based Redemption: it tracks staff verification and Used/Cancelled states,
// and is limited to one per customer per birthday-window year.
model BirthdayVoucher {
  id            Int       @id @default(autoincrement())
  code          String    @unique
  customerId    Int
  customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerName  String // snapshot
  phone         String? // snapshot — used to block multi-account abuse
  email         String? // snapshot
  rewardName    String    @default("Birthday Cupcake")
  year          Int // birthday-window anchor year this voucher belongs to
  status        String    @default("AVAILABLE") // AVAILABLE | USED | EXPIRED | CANCELLED
  issuedAt      DateTime  @default(now())
  expiresAt     DateTime
  usedAt        DateTime?
  usedBy        String? // staff member who marked it used
  deductedBeans Int       @default(0) // beans deducted on claim (0 = complimentary)
  issuedByAdmin Boolean   @default(false) // true when the manager issued it manually
  createdAt     DateTime  @default(now())

  @@unique([customerId, year])
}

// One-time verification codes for phone/email OTP login & method-linking.
model OtpCode {
  id         Int      @id @default(autoincrement())
  channel    String // "PHONE" | "EMAIL"
  identifier String // normalized E.164 phone or lowercased email
  codeHash   String // bcrypt hash of the 6-digit code (never stored in plaintext)
  purpose    String   @default("LOGIN") // "LOGIN" | "LINK"
  attempts   Int      @default(0)
  consumed   Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([identifier, createdAt])
}

// In-website notifications for a logged-in customer.
model Notification {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       String // "ORDER" | "BOOKING" | "REWARD" | "VOUCHER" | "POINTS"
  title      String
  message    String
  link       String? // in-app path to the related order/booking/reward
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// Customer feedback, ideas, or complaints. May be anonymous or tied to an account.
model Suggestion {
  id         Int       @id @default(autoincrement())
  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  name       String? // optional — may be left blank or pulled from the account
  phone      String? // optional — for contacting back
  message    String
  status     String    @default("NEW") // NEW | REVIEWED | RESOLVED
  adminNote  String?
  createdAt  DateTime  @default(now())
}

model LoyaltyTransaction {
  id           Int      @id @default(autoincrement())
  customerId   Int
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type         String // "EARN" | "REDEEM" | "ADJUST"
  amount       Int // positive = earned/added, negative = redeemed/removed
  balanceAfter Int      @default(0) // bean balance immediately after this transaction
  source       String
  refId        String? // order number, booking number, or redemption code
  note         String?
  createdAt    DateTime @default(now())
}

// A reward customers can spend beans on. Managed from the admin dashboard.
// Rewards are organised by menu category, with one or more per category.
model Reward {
  id           Int          @id @default(autoincrement())
  name         String
  description  String       @default("")
  category     String? // matches a menu category, e.g. "Espresso Based"
  cost         Int // beans required to redeem
  type         String       @default("FREE_ITEM") // "FREE_ITEM" | "DISCOUNT"
  value        Float        @default(0) // DISCOUNT rewards: $ off the order (0 = use free-item logic)
  icon         String       @default("🎁")
  image        String? // product image URL/path; falls back to icon when empty
  redeemMethod String       @default("Show voucher at counter")
  isActive     Boolean      @default(true) // show/hide on the customer page
  isAvailable  Boolean      @default(true) // can be redeemed right now
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())
  redemptions  Redemption[]
}

// A voucher created when a customer redeems a reward. Shown at the counter to claim.
model Redemption {
  id         Int       @id @default(autoincrement())
  code       String    @unique
  customerId Int
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rewardId   Int?
  reward     Reward?   @relation(fields: [rewardId], references: [id])
  rewardName String // snapshot, so it survives the reward being edited/deleted
  cost       Int // beans spent (snapshot)
  status     String    @default("ACTIVE") // "ACTIVE" | "CLAIMED" | "EXPIRED"
  createdAt  DateTime  @default(now())
  claimedAt  DateTime?
}

model Order {
  id           Int         @id @default(autoincrement())
  number       String      @unique
  customerId   Int?
  customer     Customer?   @relation(fields: [customerId], references: [id])
  customerName String
  phone        String
  email        String?

  // ---- Channel & fulfillment ----
  channel      String      @default("ONLINE") // ONLINE | POS (in-store register sale)
  shiftId      Int?        // POS: the register shift this sale belongs to
  staffId      Int?        // POS: the staff member who rang it
  staffName    String?
  orderType    String?     // POS: TAKEAWAY | DINE_IN
  tableNumber  String?     // POS dine-in table label
  terminal     String?     // POS: which register/device rang the sale (multi-terminal)
  staffPurchaseId   Int?    // set when this sale used the staff discount (for whom)
  staffPurchaseName String?
  staffTabSettledAt DateTime? // charge-to-salary sales: null = still owed on their tab, set = deducted from salary
  clientRef    String?     @unique // POS offline idempotency key (dedupes re-synced sales)
  fulfillment  String      @default("PICKUP") // PICKUP | DELIVERY
  pickupTime   String?     // pickup: "ASAP" or a scheduled time string

  // ---- Money breakdown (all Float, rounded with round2) ----
  subtotal        Float    // sum of line totals (includes add-ons & option deltas)
  addonsTotal     Float    @default(0) // portion of subtotal that is add-ons (for the summary line)
  discount        Float    @default(0) // promo-code discount
  loyaltyDiscount Float    @default(0) // discount from an applied reward voucher
  deliveryFee     Float    @default(0)
  tax             Float    @default(0)
  total           Float
  promoCode       String?
  loyaltyRedemptionCode String? // redemption voucher applied at checkout (returned on cancel)

  // ---- Status & lifecycle ----
  // Order Received → Accepted → Preparing → (Ready for Pickup → Completed)
  //                                       → (Ready for Delivery → Out for Delivery → Delivered)
  // AWAITING_PAYMENT = online order placed but not yet paid (NOT confirmed).
  // Legacy values NEW/READY/PICKED_UP are aliased in the frontend status helper.
  status       String      @default("RECEIVED") // AWAITING_PAYMENT | RECEIVED | ACCEPTED | PREPARING | READY_FOR_PICKUP | READY_FOR_DELIVERY | OUT_FOR_DELIVERY | DELIVERED | COMPLETED | CANCELLED
  cancelReason String?
  cancelledBy  String?     // "customer" | "staff" | admin name

  // ---- Payment ----
  paymentMethod String     @default("CASH_AT_PICKUP") // ONLINE | CASH_ON_DELIVERY | CASH_AT_PICKUP
  // PENDING | PAID | FAILED | CANCELLED | REFUNDED | PARTIALLY_REFUNDED | CASH_DUE | CASH_COLLECTED
  paymentStatus String     @default("CASH_DUE")
  paidAt       DateTime?

  // ---- Delivery details (snapshot — saved addresses can be edited/deleted later) ----
  zoneId            Int?
  zone              DeliveryZone? @relation(fields: [zoneId], references: [id])
  zoneName          String?
  deliveryName      String?
  deliveryPhone     String?
  addressLabel      String?  // Home | Work | Other
  addressLine       String?
  building          String?
  floor             String?
  apartment         String?
  area              String?
  landmark          String?
  deliveryInstructions String?
  lat               Float?
  lng               Float?
  estimatedDelivery String?  // snapshot of the zone's estimated delivery time
  driverName        String?  // assigned staff member / driver (text now; Driver model can come later)

  // ---- Loyalty ----
  beansEarned  Int         @default(0) // beans this order WILL earn (awarded only after paid/completed)
  beansAwarded Boolean     @default(false) // true once beans were actually credited (guards double-award)
  beansReversed Boolean    @default(false) // guards against double-removing beans on cancel/refund

  createdAt    DateTime    @default(now())
  items        OrderItem[]
  payments     Payment[]
}

// A delivery zone / area the manager defines in the admin dashboard. The system
// checks a customer's address against these before allowing a delivery checkout.
model DeliveryZone {
  id            Int      @id @default(autoincrement())
  name          String
  fee           Float    @default(0)
  minOrder      Float    @default(0) // minimum order value for delivery to this zone
  estimatedTime String   @default("") // e.g. "30–45 min"
  maxDistanceKm Float?   // location-based cap; null = name/area match only
  centerLat     Float?   // zone centre, used with maxDistanceKm
  centerLng     Float?
  isAvailable   Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  orders        Order[]
}

// A saved delivery address belonging to a logged-in customer (Home/Work/Other).
model Address {
  id           Int      @id @default(autoincrement())
  customerId   Int
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label        String   @default("Home") // Home | Work | Other
  fullName     String
  phone        String
  addressLine  String   @default("")
  building     String   @default("")
  floor        String   @default("")
  apartment    String   @default("")
  area         String   @default("")
  landmark     String   @default("")
  instructions String   @default("")
  lat          Float?
  lng          Float?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// A payment record. We NEVER store full card data — only what the gateway safely
// returns. Reusable for orders now and room/event bookings or deposits later.
model Payment {
  id             Int      @id @default(autoincrement())
  orderId        Int?
  order          Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  bookingId      Int?     // reserved for booking/event deposits
  provider       String   @default("mock")
  transactionId  String   @unique
  method         String   @default("CARD") // CARD | CASH
  amount         Float
  currency       String   @default("USD")
  // PENDING | PAID | FAILED | CANCELLED | REFUNDED | PARTIALLY_REFUNDED
  status         String   @default("PENDING")
  cardBrand      String?
  cardLast4      String?
  approvalCode   String?  // bank terminal approval/reference code (standalone card machine)
  refundedAmount Float    @default(0)
  failureReason  String?
  customerId     Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// An audit trail for sensitive admin actions (refunds, cash collection, driver
// assignment, zone/settings changes) — records who did what and when.
model AdminActivityLog {
  id          Int      @id @default(autoincrement())
  actorId     Int? // staffId for POS actions, null for admin/system
  actor       String   // admin name/email or staff name
  actorRole   String   @default("Manager") // Manager | Cashier | System …
  source      String   @default("Admin") // Admin | POS | Website | KDS | System
  section     String   @default("System") // POS | Orders | Menu | Inventory | Hanson | Shop | Preorders | Staff | Rooms | Loyalty | Payments | Register
  action      String   // price_changed | stock_received | discount_applied | shift_closed …
  entity      String?  // MenuItem | Order | InventoryItem | Shift | Staff …
  entityId    String?  // id of the affected record
  entityName  String?  // human name (product / order number / item)
  detail      String   @default("")
  oldValue    String? // JSON snapshot of the previous value
  newValue    String? // JSON snapshot of the new value
  orderNumber String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([section])
  @@index([action])
  @@index([actorId])
}

model OrderItem {
  id                  Int     @id @default(autoincrement())
  orderId             Int
  order               Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId          Int? // kept so customers can re-order the same item later
  name                String
  unitPrice           Float
  quantity            Int
  selectedOptions     String  @default("[]") // JSON-encoded SelectedOption[]
  addons              String  @default("[]") // JSON-encoded { name, price, quantity }[]
  specialInstructions String?
  lineTotal           Float
}

// A group of add-ons (e.g. "Milk", "Syrup", "Extra shots"). Managed by the admin.
model AddonGroup {
  id          Int               @id @default(autoincrement())
  name        String
  selection   String            @default("MULTIPLE") // "SINGLE" | "MULTIPLE"
  minSelect   Int               @default(0) // minimum options a customer must pick (0 = optional)
  maxSelect   Int               @default(0) // maximum options a customer may pick (0 = no limit)
  isAvailable Boolean           @default(true)
  sortOrder   Int               @default(0)
  addons      Addon[]
  assignments AddonAssignment[]
}

// A single add-on within a group, with its own price and optional max quantity.
model Addon {
  id          Int        @id @default(autoincrement())
  groupId     Int
  group       AddonGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name        String
  price       Float      @default(0)
  maxQuantity Int        @default(1) // e.g. 3 for "up to 3 extra shots"
  isAvailable Boolean    @default(true)
  sortOrder   Int        @default(0)
}

// Links an add-on group to a specific drink OR to an entire menu category.
model AddonAssignment {
  id         Int        @id @default(autoincrement())
  groupId    Int
  group      AddonGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  menuItemId Int? // assign to one drink
  category   String? // assign to a whole category
}

// Events / workshops shown on the public Events page, managed from the admin.
model Event {
  id          Int      @id @default(autoincrement())
  title       String
  category    String   @default("") // e.g. Workshop, Social Gathering, Coffee Experience
  description String   @default("")
  startTime   DateTime
  durationMins Int? // length in minutes, null = not specified
  location    String   @default("") // blank = use the café's default address
  included    String   @default("") // "what's included", one item per line
  price       Float    @default(0) // 0 = free
  spots       Int? // remaining spots, null = not tracked
  maxSpots    Int? // capacity (used to derive "Almost Full"), null = not tracked
  image       String?
  isPublished Boolean  @default(false) // false = draft, only the manager sees it
  isHidden    Boolean  @default(false) // published but temporarily pulled from the page
  isCompleted Boolean  @default(false) // event has happened
  isCancelled Boolean  @default(false) // event was called off
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

// Customer-submitted event ideas ("Suggest an Event"). Private to the manager
// unless turned into a public voting option. customerId links the account for
// admin reference only — names/phones are never shown publicly.
model EventSuggestion {
  id            Int      @id @default(autoincrement())
  customerId    Int? // linked account (private, admin reference)
  idea          String // event idea or title
  category      String   @default("")
  description   String   @default("")
  preferredDay  String   @default("")
  preferredTime String   @default("")
  name          String? // optional, private
  phone         String? // optional, private
  status        String   @default("NEW") // NEW | REVIEWED | CONSIDERING | APPROVED | REJECTED
  adminNote     String?
  createdAt     DateTime @default(now())
}

// Manager-published event ideas open for customer voting. Created manually or
// converted from an EventSuggestion. Only isPublished options are shown publicly.
model VotingOption {
  id                 Int       @id @default(autoincrement())
  title              String
  description        String    @default("")
  category           String    @default("")
  image              String?
  possibleDate       String    @default("") // freeform "possible date or time, if available"
  isPublished        Boolean   @default(false)
  closesAt           DateTime? // voting closing date, null = no deadline
  status             String    @default("OPEN") // OPEN | CLOSED | SELECTED
  sourceSuggestionId Int? // EventSuggestion it was converted from (if any)
  convertedEventId   Int? // Event draft created when this idea was selected (if any)
  sortOrder          Int       @default(0)
  createdAt          DateTime  @default(now())
  votes              Vote[]
}

// One row per customer per voting option. The unique constraint is what makes
// duplicate voting impossible (rapid clicks, refreshes, multiple sessions).
model Vote {
  id             Int          @id @default(autoincrement())
  votingOptionId Int
  customerId     Int
  createdAt      DateTime     @default(now())
  votingOption   VotingOption @relation(fields: [votingOptionId], references: [id], onDelete: Cascade)

  @@unique([votingOptionId, customerId])
}

// Customers who opted in to WhatsApp offers & updates.
model Subscriber {
  id        Int      @id @default(autoincrement())
  name      String?
  phone     String   @unique
  createdAt DateTime @default(now())
}

// Admin-controlled homepage announcement banner.
model Banner {
  id         Int       @id @default(autoincrement())
  title      String
  text       String    @default("")
  image      String?
  buttonText String?
  buttonLink String?
  startDate  DateTime?
  endDate    DateTime?
  isVisible  Boolean   @default(true)
  createdAt  DateTime  @default(now())
}

// A POS staff member who signs into the register with a PIN.
model StaffUser {
  id        Int      @id @default(autoincrement())
  name      String
  pinHash   String
  role      String   @default("CASHIER") // CASHIER | MANAGER
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Staff attendance — one clock-in, with a clock-out once they leave. Open entry
// (clockOut null) = currently on the clock.
model TimeEntry {
  id        Int       @id @default(autoincrement())
  staffId   Int
  staffName String
  clockIn   DateTime  @default(now())
  clockOut  DateTime?
  createdAt DateTime  @default(now())

  @@index([staffId, clockIn])
}

// A register shift / cash-drawer session.
model Shift {
  id           Int            @id @default(autoincrement())
  staffId      Int
  staffName    String
  terminal     String         @default("Register 1") // which register/device this drawer belongs to
  status       String         @default("OPEN") // OPEN | CLOSED
  openingFloat Float          @default(0)
  cashPayIns   Float          @default(0)
  cashPayOuts  Float          @default(0)
  countedCash  Float? // cash counted at close
  expectedCash Float? // float + cash sales + payins − payouts
  difference   Float? // counted − expected
  note         String?
  openedAt     DateTime       @default(now())
  closedAt     DateTime?
  movements    CashMovement[]
}

// A manual cash pay-in / pay-out against a shift (petty cash, tips out, etc.).
model CashMovement {
  id        Int      @id @default(autoincrement())
  shiftId   Int
  shift     Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  type      String // PAYIN | PAYOUT
  amount    Float
  reason    String   @default("")
  staffName String
  createdAt DateTime @default(now())
}

model Booking {
  id            Int       @id @default(autoincrement())
  number        String    @unique
  roomId        Int
  room          Room      @relation(fields: [roomId], references: [id])
  customerId    Int?
  customer      Customer? @relation(fields: [customerId], references: [id])
  customerName  String
  phone         String
  startTime     DateTime
  endTime       DateTime
  durationHours Int
  peopleCount   Int
  notes         String?
  total         Float
  status        String    @default("CONFIRMED") // PENDING | CONFIRMED | IN_USE | COMPLETED | CANCELLED | NO_SHOW
  beansEarned   Int       @default(0)
  bookedBy      String? // register staff who booked it for a walk-in (null = online)
  createdAt     DateTime  @default(now())
}

// ---- Ingredient / raw-materials inventory (Bill-of-Materials) -----------------
// A single stock item the shop keeps: raw (milk, beans, cups) OR a simple finished
// good (croissant, water bottle). Menu items consume these via RecipeComponent.
model InventoryItem {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  category    String    @default("") // Dairy, Coffee, Packaging, Syrups, Bakery, Powders…
  unit        String    @default("pcs") // liters, ml, g, kg, pcs…
  quantity    Float     @default(0) // current on-hand, expressed in `unit`
  minQty      Float     @default(0) // low-stock threshold
  costPerUnit Float     @default(0) // for stock valuation + cost reports
  supplier    String?
  expiryDate  DateTime?
  trackExpiry Boolean   @default(false)
  batchLot    String? // delivery batch / lot reference (optional)
  storageLocation String? // Fridge, Freezer, Dry Storage, Bar… (optional)
  notes       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  movements   InventoryMovement[]
  recipe      RecipeComponent[]
}

// Every change to an inventory item's quantity — the running total is the sum of deltas.
model InventoryMovement {
  id              Int           @id @default(autoincrement())
  inventoryItemId Int
  item            InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  delta           Float // signed change, in the item's unit
  balance         Float // resulting on-hand quantity
  type            String // SALE | RECEIVE | WASTE | EXPIRED | DAMAGED | ADJUST | COUNT | REFUND_REVERSAL
  reason          String?
  staffName       String?
  orderId         Int? // set for sale deductions / refund reversals
  invoiceNo       String? // supplier invoice on RECEIVE
  costPerUnit     Float? // captured on RECEIVE
  restockId       Int? // groups the RECEIVE movements that came from one restock delivery
  createdAt       DateTime      @default(now())

  @@index([inventoryItemId, createdAt])
}

// ---- Retail shop (physical products: Illy capsules, machines, beans…) --------
// Deliberately separate from café MenuItem: these are physical goods sold as-is
// (simple quantity deduction, no recipe), online and/or in the POS, with an
// optional preorder path for items not kept in stock.
model ShopCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  sortOrder Int      @default(0)
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ShopProduct {
  id              Int      @id @default(autoincrement())
  name            String
  category        String   @default("")
  brand           String? // e.g. "Illy"
  description     String   @default("")
  images          String   @default("[]") // JSON-encoded string[] (first = primary)
  price           Float
  costPrice       Float    @default(0) // for margin reports
  sku             String?
  quantity        Float    @default(0) // on-hand; simple deduction on sale
  minQty          Float    @default(0) // low-stock threshold
  availableOnline Boolean  @default(true) // show on the public /shop page
  availablePos    Boolean  @default(true) // sellable at the register
  allowPreorder   Boolean  @default(false) // orderable even when out of stock
  preorderEta     String? // e.g. "3–7 days"
  featured        Boolean  @default(false)
  sortOrder       Int      @default(0)
  isHidden        Boolean  @default(false) // hidden everywhere (kept for history)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  movements       ShopStockMovement[]
}

// Every change to a shop product's on-hand quantity (audit trail).
model ShopStockMovement {
  id        Int         @id @default(autoincrement())
  productId Int
  product   ShopProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  delta     Float // signed
  balance   Float // resulting on-hand
  type      String // RECEIVE | SALE | ADJUST | COUNT
  reason    String?
  staffName String?
  orderId   Int? // set when a POS/online sale deducted it
  createdAt DateTime    @default(now())

  @@index([productId, createdAt])
}

// A customer preorder for a shop product not kept in stock (machines, special
// items). Does NOT deduct stock — the manager fulfils it through the status
// pipeline and contacts the customer.
model Preorder {
  id               Int      @id @default(autoincrement())
  number           String   @unique // PO-XXXX
  productId        Int?
  productName      String
  quantity         Int      @default(1)
  unitPrice        Float    @default(0)
  total            Float    @default(0)
  customerName     String
  phone            String
  customerId       Int?
  notes            String?
  status           String   @default("NEW") // NEW | CONFIRMED | ORDERED | ARRIVED | READY | COMPLETED | CANCELLED
  estimatedArrival String?
  paymentStatus    String   @default("UNPAID") // UNPAID | DEPOSIT | PAID
  createdBy        String? // "Online" or the POS staff who took it
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ---- Suppliers & restocking (supplier receiving) ----------------------------
// A supplier the shop buys stock from (dairy, coffee, packaging…).
model Supplier {
  id            Int       @id @default(autoincrement())
  name          String
  contactPerson String?
  phone         String?
  whatsapp      String?
  email         String?
  address       String?
  notes         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// One supplier-receiving transaction: multiple stock items received in one delivery.
// Saving a restock increases each item's on-hand quantity and writes a RECEIVE
// movement per line (tagged with this restock's id) for a full audit trail.
model Restock {
  id            Int           @id @default(autoincrement())
  number        String        @unique // RS-XXXX
  supplierId    Int? // optional link to a managed Supplier
  supplierName  String // snapshot (free-text or the chosen supplier's name)
  supplierPhone String?
  invoiceNo     String?
  invoicePhoto  String? // uploaded invoice image URL
  deliveryDate  DateTime      @default(now())
  receivedBy    String? // who took the delivery
  notes         String?
  itemCount     Int           @default(0)
  totalCost     Float         @default(0)
  createdBy     String? // admin/manager who recorded it
  createdAt     DateTime      @default(now())
  // Voiding reverses the delivery's stock (fully logged) — used to correct mistakes.
  voidedAt      DateTime?
  voidedBy      String?
  voidReason    String?
  lines         RestockLine[]
}

// One received item line within a restock.
model RestockLine {
  id              Int       @id @default(autoincrement())
  restockId       Int
  restock         Restock   @relation(fields: [restockId], references: [id], onDelete: Cascade)
  inventoryItemId Int
  itemName        String // snapshot of the item name at receiving time
  quantity        Float
  unit            String
  costPerUnit     Float     @default(0)
  totalCost       Float     @default(0)
  expiryDate      DateTime?
  batchNo         String?
  notes           String?

  @@index([restockId])
}

// One line of a menu item's recipe: how much of an inventory item it consumes.
// size = null → applies to every size; addonId set → consumed when that add-on is chosen.
model RecipeComponent {
  id              Int           @id @default(autoincrement())
  menuItemId      Int
  size            String? // null = all sizes, else "Small"/"Medium"/"Large"
  addonId         Int? // null = base recipe, else tied to a specific add-on
  inventoryItemId Int
  item            InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  quantity        Float // amount of `item` consumed, in the item's unit
  // For a REPLACE add-on line: the base ingredient this one swaps out (e.g. Oat
  // Milk replaces Milk) — when the add-on is chosen, the base item is not deducted.
  replacesInventoryItemId Int?
  createdAt       DateTime      @default(now())

  @@index([menuItemId])
  @@index([addonId])
}
